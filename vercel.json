{
  "functions": {
    "**/*.php": {
      "runtime": "vercel-php@0.9.0"
    }
  },
  "routes": [
    {
      "src": "/",
      "dest": "/index.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "BASE_PATH": ""
  }
}
