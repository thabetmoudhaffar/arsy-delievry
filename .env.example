# Environment Mode (local or production)
APP_ENV=local

# Application Base URL & Path Configuration
# If the app is deployed in the root directory (e.g. domain.com), set BASE_PATH to ""
# and APP_URL to "https://domain.com".
BASE_PATH="/arsy%20delievry"
APP_URL="http://localhost/arsy%20delievry"

# Database Configuration
DB_HOST=localhost
DB_NAME=arsy_delivery
DB_USER=root
DB_PASS=""
DB_CHARSET=utf8mb4

# Google OAuth Configuration
# (Set GOOGLE_CLIENT_ID to "YOUR_GOOGLE_CLIENT_ID" to use the built-in mock sandbox)
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
