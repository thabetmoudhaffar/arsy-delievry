# Environment Mode (local or production)
APP_ENV=local

# Application Base URL & Path Configuration
# If deployed on Vercel, BASE_PATH is automatically set to ""
# If deployed locally via XAMPP, use "/arsy%20delievry"
BASE_PATH="/arsy%20delievry"
APP_URL="http://localhost/arsy%20delievry"

# Database Configuration (Use external MySQL for Vercel, e.g. TiDB, PlanetScale, Aiven)
DB_HOST=localhost
DB_NAME=arsy_delivery
DB_USER=root
DB_PASS=""
DB_CHARSET=utf8mb4

# Google OAuth Configuration
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
